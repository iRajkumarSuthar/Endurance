NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=production
APP_ENV=production

# Backend/platform decision
AUTH_BACKEND=firebase
VERIFICATION_MODE=async
VERIFICATION_TARGET_MS=3500
FORCE_HTTPS=true
SECURITY_CSP_ENABLED=true
SESSION_COOKIE_NAME=endurance_session
SESSION_COOKIE_SECURE=true

# Firebase web config (public)
NEXT_PUBLIC_FIREBASE_API_KEY=your_public_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase admin (server-only secrets)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_BUCKET_REGION=us-central1

# Upload/verification controls
MAX_FILE_SIZE_BYTES=12582912
MIN_FILE_SIZE_BYTES=20480
SUPPORTED_DOCUMENT_TYPES="application/pdf,image/jpeg,image/png"

# Security / sessions
SESSION_TTL_SECONDS=3600
API_RATE_LIMIT_RPM=120
